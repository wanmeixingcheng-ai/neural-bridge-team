APP_PASSWORD=
APP_AUTH_SECRET=

# Upstash Redis, used for production session store and global API rate limits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Postgres or Neon, used for users, permissions, audit events, and task history.
DATABASE_URL=

# Model provider keys. Prefer Vercel environment variables in production.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Production must remain false. Client-supplied provider keys are ignored in production even if this is set to true.
ENABLE_CLIENT_API_KEYS=false

# Codex task delivery. Production requires CODEX_TASK_ADMIN_TOKEN.
CODEX_TASK_ADMIN_TOKEN=
CODEX_TASK_AUTO_RUN=false
GITHUB_TASK_TOKEN=
GITHUB_TASK_REPO=
CODEX_TASK_WEBHOOK_URL=

# GitHub save transit is disabled by default because it sends content to GitHub Issues.
ENABLE_GITHUB_SAVE_TRANSIT=false
